import "lib/math.deor"
import "lib/convert.deor"

fn void main()
	print("Beginning simple ")
	value as compute_with_leibniz(100)
	print(value)

fn float compute_with_leibniz(int iterations)
	float value = 0.0
	for i in range(iterations)
		is_even as i%2 is 0
		rust
			let decimal_i: f64 = i as f64;

		float denom = 1.0 + decimal_i*2.0

		if is_even
			value = value + 1.0/denom
		else
			value = value - 1.0/denom

	float result = 4.0 * value
	return result

